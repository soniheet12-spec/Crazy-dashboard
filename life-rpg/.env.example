# ─── Google OAuth (Calendar read-only) ───────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable the "Google Calendar API" and configure the OAuth consent screen.
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev URL. On Vercel set this to your production URL (https://...).
NEXTAUTH_URL=http://localhost:3000

# ─── Optional: AI weekly recap (Phase 2) ─────────────────────────────────────
# If set, the "Generate weekly recap" button calls Anthropic's Claude API.
# Leave blank to keep the feature disabled (it degrades gracefully).
ANTHROPIC_API_KEY=
